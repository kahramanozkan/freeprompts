      ],
      "notesInFlow": true,
      "notes": "DIKKAT: Gem talimatlarınızı (prompt) buraya yapıştırın."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro-latest:generateContent",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "x-goog-api-key",
              "value": "BURAYA_GEMINI_API_KEY_YAZIN"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"contents\": [{ \"parts\": [{ \"text\": \"Bana yeni bir prompt üret. Çıktıyı kesinlikle aşağıdaki JSON formatında ver:\\n{\\n \\\"title\\\": \\\"...\\\",\\n \\\"content\\\": \\\"...\\\",\\n \\\"json_prompt\\\": \\\"...\\\",\\n \\\"tags\\\": [\\\"...\\\"],\\n \\\"category\\\": \\\"...\\\",\\n \\\"theme\\\": \\\"...\\\",\\n \\\"group\\\": \\\"...\\\",\\n \\\"share_text_twitter\\\": \\\"...\\\",\\n \\\"share_text_facebook\\\": \\\"...\\\",\\n \\\"share_text_pinterest\\\": \\\"...\\\",\\n \\\"share_text_whatsapp\\\": \\\"...\\\"\\n}\\n\\nÖzel Talimatlar:\\n\" + $json.gem_instructions }] }] } }}",
        "options": {}
      },
      "id": "e331c2bb-1234-4b5c-9c9d-123456789abc",
      "name": "Generate Prompt (LLM)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        400,
        200
      ],
      "notesInFlow": true,
      "notes": "DIKKAT: Sadece API Anahtarınızı girin."
    },
    {
      "parameters": {
        "jsCode": "const text = $input.first().json.candidates[0].content.parts[0].text;\nlet parsed = {};\n\n// 1. Önce standart JSON formatını yakalamayı deneriz\ntry {\n  const firstBrace = text.indexOf('{');\n  const lastBrace = text.lastIndexOf('}');\n  if (firstBrace !== -1 && lastBrace !== -1 && firstBrace < 200) {\n    const jsonString = text.substring(firstBrace, lastBrace + 1);\n    const tempParsed = JSON.parse(jsonString);\n    if (tempParsed.title || tempParsed.content) {\n      parsed = tempParsed;\n    }\n  }\n} catch(e) {}\n\n// 2. Regex parsing\nif (!parsed.title) {\n  const extract = (regex) => {\n    const match = text.match(regex);\n    return match ? match[1].trim() : \"\";\n  };\n\n  parsed = {\n    id: extract(/Prompt number:\\s*(.*?)(?=\\n|$)/i),\n    title: extract(/Title:\\s*(.*?)(?=\\n|$)/i),\n    content: extract(/Prompt:\\s*([\\s\\S]*?)(?=JSON Prompt:)/i),\n    json_prompt: extract(/JSON Prompt:\\s*([\\s\\S]*?)(?=Tags:)/i),\n    tags: extract(/Tags:\\s*(.*?)(?=\\n|$)/i),\n    category: extract(/(?:Sub-theme \\/ Category:|Category:)\\s*(.*?)(?=\\n|$)/i),\n    theme: extract(/Theme:\\s*(.*?)(?=\\n|$)/i),\n    group: extract(/Group:\\s*(.*?)(?=\\n|$)/i),\n    share_text_twitter: extract(/(?:X share text:|Twitter share text:)\\s*([\\s\\S]*?)(?=Facebook share text:)/i),\n    share_text_facebook: extract(/Facebook share text:\\s*([\\s\\S]*?)(?=Pinterest share text:)/i),\n    share_text_pinterest: extract(/Pinterest share text:\\s*([\\s\\S]*?)(?=Whatsapp share text:)/i),\n    share_text_whatsapp: extract(/Whatsapp share text:\\s*([\\s\\S]*?)(?=$)/i)\n  };\n\n  if (parsed.json_prompt) {\n      parsed.json_prompt = parsed.json_prompt.replace(/\\x60\\x60\\x60json/gi, '').replace(/\\x60\\x60\\x60/g, '').trim();\n  }\n  if (parsed.content) {\n      parsed.content = parsed.content.replace(/\\x60\\x60\\x60text/gi, '').replace(/\\x60\\x60\\x60/g, '').trim();\n  }\n  if (parsed.tags) {\n      parsed.tags = parsed.tags.replace(/[\\[\\]\"]/g, '').trim();\n  }\n}\n\nreturn { json: parsed };"
      },
      "id": "parse-json-node-123",
      "name": "Parse JSON",
      "type": "n8n-nodes-base.code",
